# ─── Agencia de Domicilios - Variables de Entorno ─────────────────────────────
# Copia este archivo como .env y ajusta los valores para tu entorno.

# Puerto del servidor (default: 3000)
PORT=3000

# Secreto para firmar tokens JWT (OBLIGATORIO en producción)
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-seguro-en-produccion

# Duración del token JWT (default: 12h)
TOKEN_TTL=12h

# CORS: orígenes permitidos (separados por coma). Usar * para todos.
# Ejemplo: https://midominio.com,https://admin.midominio.com
CORS_ORIGIN=*

# Ruta de la base de datos SQLite (default: ./db/data.sqlite)
DB_PATH=./db/data.sqlite

# Nivel de log: error, warn, info, debug (default: info)
LOG_LEVEL=info

# Retención del historial de ubicaciones en días (default: 30)
LOCATION_HISTORY_RETENTION_DAYS=30
