# Server
NODE_ENV=production
PORT=3000
PUBLIC_URL=https://your-service.onrender.com
CORS_ORIGIN=https://your-service.onrender.com

# Database and authentication
DATABASE_URL=
JWT_SECRET=replace-with-a-long-random-secret

# OpenAI monitoring assistant (server-side only; never expose this key in frontend code)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
ASSISTANT_TIMEOUT_MS=30000
ASSISTANT_MAX_OUTPUT_TOKENS=900
ASSISTANT_RATE_LIMIT_WINDOW_MS=60000
ASSISTANT_RATE_LIMIT_MAX=10
