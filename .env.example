# ─── Agencia de Domicilios - Variables de Entorno ─────────────────────────────
# Copia este archivo como .env y ajusta los valores para tu entorno.
# En produccion, JWT_SECRET es OBLIGATORIO.

# ─── General ─────────────────────────────────────────────────────────────────

# Entorno: development | production
NODE_ENV=development

# Puerto del servidor (default: 3000)
PORT=3000

# ─── Seguridad / JWT ─────────────────────────────────────────────────────────

# Secreto para firmar tokens JWT (OBLIGATORIO en producción)
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-seguro-en-produccion

# Duración del access token (default: 15m)
TOKEN_TTL=15m

# Duración del refresh token (default: 7d)
REFRESH_TOKEN_TTL=7d

# ─── CORS ────────────────────────────────────────────────────────────────────

# Orígenes permitidos (separados por coma). Usar * para todos.
# Ejemplo: https://midominio.com,https://admin.midominio.com
CORS_ORIGIN=*

# ─── Base de Datos ───────────────────────────────────────────────────────────

# Ruta de la base de datos SQLite (default: ./db/data.sqlite)
DB_PATH=./db/data.sqlite

# Intervalo de auto-guardado en ms (default: 5000)
DB_SAVE_INTERVAL=5000

# ─── Rate Limiting ──────────────────────────────────────────────────────────

# Máximo de requests por minuto para API general (default: 120)
API_RATE_LIMIT=120

# Máximo de intentos de auth en 15 minutos (default: 10)
AUTH_RATE_LIMIT=10

# ─── Login ───────────────────────────────────────────────────────────────────

# Intentos máximos de login antes de bloqueo (default: 5)
MAX_LOGIN_ATTEMPTS=5

# Minutos de bloqueo después de exceder intentos (default: 15)
LOCKOUT_MINUTES=15

# ─── Tracking / Ubicación ───────────────────────────────────────────────────

# Milisegundos sin reportar para marcar conductor offline (default: 30000)
OFFLINE_AFTER_MS=30000

# Intervalo de verificación de conductores offline en ms (default: 10000)
OFFLINE_CHECK_INTERVAL=10000

# Retención del historial de ubicaciones en días (default: 30)
LOCATION_HISTORY_RETENTION_DAYS=30

# ─── Caché ───────────────────────────────────────────────────────────────────

# Max-age para assets estáticos en segundos (default: 86400 = 24h)
STATIC_CACHE_MAX_AGE=86400

# ─── Logging ─────────────────────────────────────────────────────────────────

# Nivel de log: error, warn, info, debug (default: info)
LOG_LEVEL=info

# ─── Graceful Shutdown ───────────────────────────────────────────────────────

# Timeout para forzar cierre si graceful shutdown no completa (default: 10000ms)
SHUTDOWN_TIMEOUT=10000
